    "autoprefixer": "^10.4.0",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.34.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-tsparticles": "^2.12.2",
    "resend": "^6.9.2",
    "tailwindcss": "^3.4.0",
    "tsparticles": "^3.9.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "typescript": "5.3.3"
  }
