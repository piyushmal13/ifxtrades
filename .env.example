# ================================================================
# IFXTrades — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ================================================================

# ── Supabase ─────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe ───────────────────────────────────────────────────────
# From: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
# From: Stripe Dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (Email) ───────────────────────────────────────────────
# From: resend.com → API Keys
RESEND_API_KEY=re_...

# ── Site URL ─────────────────────────────────────────────────────
# Production: https://www.ifxtrades.com
# Local dev:  http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://www.ifxtrades.com

# ── Admin Bootstrap (optional) ──────────────────────────────────
# One-time token for the first admin account creation via /admin-access
# Generate with: openssl rand -hex 32
IFX_ADMIN_BOOTSTRAP_TOKEN=

# Comma-separated emails that are auto-elevated to admin
IFX_ADMIN_BOOTSTRAP_EMAILS=

# ── Feature Flags ─────────────────────────────────────────────────
NEXT_PUBLIC_AUTH_V1_ENABLED=true
NEXT_PUBLIC_OTP_COOLDOWN_ENABLED=true
NEXT_PUBLIC_ADMIN_OTP_RETRY=false
